# Copie ce fichier en `server/.env` et remplis les valeurs.
# `.env` ne doit JAMAIS être commit (clés secrètes) — vérifie qu'il est bien dans .gitignore.

# --- Supabase (Settings → API dans ton projet) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# La clé "service_role" (PAS la clé "anon") : le serveur doit pouvoir écrire dans toutes les tables.
SUPABASE_SERVICE_ROLE_KEY=
# La clé "anon" / "public" (différente de service_role ci-dessus) : sert aux comptes locaux
# (Settings → API → clé "anon" / "public"), pour parler à Supabase Auth.
SUPABASE_ANON_KEY=

# --- Mode dev SANS Twitch (tant que l'app Twitch n'est pas créée) ---
# true → active GET /auth/dev/login?pseudo=TonPseudo, qui fait le même onboarding que le
# vrai login Twitch mais sans passer par Twitch. À repasser à false (ou supprimer la ligne)
# une fois le vrai login Twitch branché.
DEV_AUTH_ENABLED=true

# --- Twitch (dev.twitch.tv/console/apps, voir server/README.md) — à remplir plus tard ---
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:8787/auth/twitch/callback

# --- Twitch en live (Brique 6) ---
# N'importe quelle longue chaîne aléatoire. Protège /auth/twitch/streamer/login?cle=... :
# c'est TOI (le streamer) qui visites cette URL une seule fois pour autoriser l'appli à lire
# les chatters et les récompenses de ta chaîne — sans ce secret, n'importe qui pourrait le faire.
TWITCH_STREAMER_SECRET=change-moi-en-une-longue-chaine-aleatoire
# Généré par toi (même principe que SESSION_SECRET) et collé aussi dans la config EventSub côté
# Twitch : sert à vérifier qu'une notification webhook vient bien de Twitch.
TWITCH_EVENTSUB_SECRET=change-moi-en-une-longue-chaine-aleatoire
# Protège /cron/presence, appelée toutes les 1 min par un service externe (cron-job.org) —
# Get Chatters n'est pas de l'EventSub, ça se sonde soi-même, d'où ce 2e mécanisme.
CRON_SECRET=change-moi-en-une-longue-chaine-aleatoire

# --- Serveur ---
# N'importe quelle longue chaîne aléatoire, sert à signer les cookies de session.
SESSION_SECRET=change-moi-en-une-longue-chaine-aleatoire
PORT=8787
# L'URL du frontend (Brique 5) — utilisée pour les redirections après login et le CORS.
FRONTEND_URL=http://localhost:5173
